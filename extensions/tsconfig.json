{
    "compilerOptions": {
        "target": "ES2021",
        "module": "CommonJS",
        "sourceMap": false,
        "noImplicitAny": true,
        "esModuleInterop": true,
        "moduleResolution": "node",
        "strict": true,
        "alwaysStrict": true,
        "types": ["node"],
        "forceConsistentCasingInFileNames": true,
        "noFallthroughCasesInSwitch": true,
        "outDir": "build"
    },
    "include": ["src/**/*"]
}
