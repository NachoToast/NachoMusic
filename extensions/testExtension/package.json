{
    "name": "test-extension",
    "version": "1.0.0",
    "main": "build/testExtension/src/index.js",
    "license": "MIT",
    "scripts": {
        "build": "tsc",
        "typecheck": "tsc --noEmit",
        "start": "node .",
        "lint": "eslint \"src/**\" --ext .ts --max-warnings=0",
        "dev": "nodemon src/index.ts",
        "check-all": "yarn lint && yarn typecheck"
    },
    "dependencies": {
        "uuid": "^8.3.2",
        "websocket": "^1.0.34"
    },
    "devDependencies": {
        "@types/node": "^17.0.36",
        "@types/uuid": "^8.3.4",
        "@types/websocket": "^1.0.5",
        "@typescript-eslint/eslint-plugin": "^5.27.0",
        "@typescript-eslint/parser": "^5.27.0",
        "eslint": "^8.16.0",
        "eslint-config-prettier": "^8.5.0",
        "nodemon": "^2.0.16",
        "prettier": "^2.6.2",
        "ts-node": "^10.8.0",
        "typescript": "^4.7.2"
    },
    "nodemonConfig": {
        "watch": [
            "src"
        ],
        "ext": "ts"
    }
}
