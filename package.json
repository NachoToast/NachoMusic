{
    "name": "nachomusic",
    "version": "0.0.1",
    "repository": "https://github.com/NachoToast/NachoMusic.git",
    "author": "NachoToast <32235595+NachoToast@users.noreply.github.com>",
    "license": "MIT",
    "private": true,
    "scripts": {
        "build:app": "webpack --config app/webpack.config.js --mode production",
        "build:extensions": "node extensions/source/buildAll.js",
        "dev:app": "nodemon --config app/nodemon.json",
        "dev:extensions": "nodemon --config extensions/source/nodemon.json",
        "typecheck:app": "tsc -p app/tsconfig.json --noEmit",
        "typecheck:extensions": "tsc -p extensions/source/tsconfig.json --noEmit",
        "lint:app": "eslint \"app/source/**\" --ext .ts --max-warnings=0",
        "lint:extensions": "eslint \"extensions/source/**/*.ts\" --ext .ts --max-warnings=0",
        "start": "neu run",
        "update": "neu update"
    },
    "dependencies": {
        "@neutralinojs/neu": "^9.3.1",
        "@types/minimist": "^1.2.2",
        "@types/node": "^17.0.36",
        "@types/uuid": "^8.3.4",
        "@types/websocket": "^1.0.5",
        "@typescript-eslint/eslint-plugin": "^5.26.0",
        "@typescript-eslint/parser": "^5.26.0",
        "chalk": "^5.0.1",
        "eslint": "^8.16.0",
        "eslint-config-prettier": "^8.5.0",
        "minimist": "^1.2.6",
        "nodemon": "^2.0.16",
        "prettier": "^2.6.2",
        "ts-loader": "^9.3.0",
        "ts-node": "^10.8.0",
        "typescript": "^4.7.2",
        "uuid": "^8.3.2",
        "webpack": "^5.72.1",
        "webpack-cli": "^4.9.2",
        "websocket": "^1.0.34"
    }
}
