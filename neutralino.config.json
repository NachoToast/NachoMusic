{
    "applicationId": "js.nachotoast.nachomusic",
    "version": "1.0.0",
    "defaultMode": "window",
    "documentRoot": "/app/build/",
    "url": "/",
    "enableServer": true,
    "enableNativeAPI": true,
    "nativeAllowList": [
        "app.*",
        "clipboard.*",
        "computer.*",
        "debug.*",
        "events.*",
        "extensions.*",
        "filesystem.*",
        "os.*",
        "storage.*",
        "updater.*",
        "window.*"
    ],
    "modes": {
        "window": {
            "title": "Nacho Music",
            "width": 800,
            "height": 500,
            "minWidth": 400,
            "minHeight": 200,
            "icon": "/app/build/icon.png",
            "enableInspector": true
        }
    },
    "cli": {
        "binaryName": "Nacho Music",
        "resourcesPath": "/app/build",
        "extensionsPath": "/extensions/build/",
        "clientLibrary": "/app/build/neutralino.js",
        "binaryVersion": "4.6.0",
        "clientVersion": "3.5.0"
    },
    "logging": {
        "enabled": true,
        "writeToLogFile": false
    },
    "enableExtensions": true,
    "extensions": [
        {
            "id": "js.neutralino.sample.my_nodejs_extension",
            "command": "node extensions/testExtension"
        }
    ]
}
